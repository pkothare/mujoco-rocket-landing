<!-- Rocket landing scene (modelled after mujoco_menagerie/skydio_x2/scene.xml) -->
<mujoco model="rocket_scene">
  <include file="rocket.xml"/>

  <statistic center="0 0 0" extent="200"/>

  <visual>
    <headlight diffuse="0.6 0.6 0.6" ambient="0.3 0.3 0.3" specular="0 0 0"/>
    <global offwidth="640" offheight="480"/>
    <quality shadowsize="4096"/>
    <map znear="0.005" zfar="50" shadowclip="0.1"/>
    <rgba haze="0.15 0.25 0.35 1"/>
  </visual>

  <asset>
    <texture type="skybox" file="desert.png" gridsize="3 4" gridlayout=".U..LFRB.D.."/>
    <texture type="2d" name="groundplane" builtin="checker" mark="edge"
             rgb1="0.25 0.35 0.45" rgb2="0.15 0.2 0.25" markrgb="0.8 0.8 0.8"
             width="300" height="300"/>
    <material name="groundplane" texture="groundplane" texuniform="true"
              texrepeat="0.05 0.05" reflectance="0.2"/>
  </asset>

  <worldbody>
    <light pos="0 0 1.5" dir="0 0 -1" directional="true"/>
    <geom name="ground" type="box" size="5000 5000 0.5" pos="0 0 -0.5"
          material="groundplane" contype="1" conaffinity="1"/>
  </worldbody>
</mujoco>
